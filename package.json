{
  "name": "react-native-in-app-devtools",
  "version": "0.0.2",
  "private": true,
  "description": "In-app devtools for React Native. Network inspector with redaction, RTK Query adapter, and optional Redux/Zustand/Jotai state logger.",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./axios": "./src/axios/index.ts",
    "./rtk": "./src/rtk/index.ts",
    "./redux": "./src/redux/index.ts",
    "./zustand": "./src/zustand/index.ts",
    "./jotai": "./src/jotai/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "prepare": "echo 'No build step - shipping TypeScript source'"
  },
  "keywords": [
    "react-native",
    "in-app-devtools",
    "react-native-in-app-devtools",
    "react-native-api-inspector",
    "react-native-api-logger",
    "react-native-api-tracker",
    "devtools",
    "network-inspector",
    "api-inspector",
    "http-debugger",
    "axios",
    "rtk-query",
    "redux",
    "zustand",
    "jotai",
    "debugger",
    "redaction",
    "curl",
    "ios",
    "android"
  ],
  "author": {
    "name": "Ihab Khafagaa",
    "email": "ihabkhafaga3@gmail.com",
    "url": "https://github.com/khafagaa"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/khafagaa/react-native-in-app-devtools.git"
  },
  "homepage": "https://github.com/khafagaa/react-native-in-app-devtools#readme",
  "bugs": {
    "url": "https://github.com/khafagaa/react-native-in-app-devtools/issues"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-native": ">=0.70.0",
    "react-native-svg": ">=13.0.0",
    "axios": ">=1.0.0",
    "@react-native-clipboard/clipboard": ">=1.11.0",
    "expo-clipboard": ">=6.0.0",
    "@reduxjs/toolkit": ">=1.9.0",
    "redux": ">=4.0.0",
    "zustand": ">=4.0.0",
    "jotai": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "axios": {
      "optional": true
    },
    "@react-native-clipboard/clipboard": {
      "optional": true
    },
    "expo-clipboard": {
      "optional": true
    },
    "@reduxjs/toolkit": {
      "optional": true
    },
    "redux": {
      "optional": true
    },
    "zustand": {
      "optional": true
    },
    "jotai": {
      "optional": true
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "devDependencies": {
    "@react-native-clipboard/clipboard": "^1.16.2",
    "@types/react": "~19.1.0",
    "axios": "^1.18.1",
    "react": "19.1.0",
    "react-native": "0.79.5",
    "react-native-svg": "15.15.4",
    "typescript": "~5.9.2"
  }
